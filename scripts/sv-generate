  "google/codegemma-7b"
]

model_aliases = {
  "gpt-5.2": "gpt-5.2-2025-12-11",
  "gpt-5.2-pro": "gpt-5.2-pro-2025-12-11",
  "gpt-5": "gpt-5-2025-08-07",
  "gpt-4o": "gpt-4o-2024-11-20",
